{"allContent":{"docusaurus-plugin-content-docs":{"default":{"loadedVersions":[{"versionName":"current","label":"Next","banner":null,"badge":false,"noIndex":false,"className":"docs-version-current","path":"/lynx-onboarding/docs","tagsPath":"/lynx-onboarding/docs/tags","isLast":true,"routePriority":-1,"sidebarFilePath":"D:\\LYNX\\LYNX-Onboarding-Setup\\lynx-docusaurus-repo\\sidebars.ts","contentPath":"D:\\LYNX\\LYNX-Onboarding-Setup\\lynx-docusaurus-repo\\docs","docs":[{"id":"intro","title":"LYNX Real Estate Group Onboarding Guide","description":"Welcome to the LYNX onboarding portal","source":"@site/docs/intro.md","sourceDirName":".","slug":"/intro","permalink":"/lynx-onboarding/docs/intro","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"intro","title":"LYNX Real Estate Group Onboarding Guide","description":"Welcome to the LYNX onboarding portal"},"sidebar":"docsSidebar","next":{"title":"1.1 Our Team & What We Stand For","permalink":"/lynx-onboarding/docs/module-1/team-values"}},{"id":"module-1/alberta-licensing","title":"1.4 Alberta Licensing in Plain English","description":"Your licensing course taught you the rules. This section tells you what those rules actually mean when you're sitting across from a client. When in doubt on anything compliance-related — call your Mentor. Never guess.","source":"@site/docs/module-1/alberta-licensing.md","sourceDirName":"module-1","slug":"/module-1/alberta-licensing","permalink":"/lynx-onboarding/docs/module-1/alberta-licensing","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"alberta-licensing","title":"1.4 Alberta Licensing in Plain English"},"sidebar":"docsSidebar","previous":{"title":"1.3 Your First 30 Days","permalink":"/lynx-onboarding/docs/module-1/first-30-days"},"next":{"title":"1.5 Team Expectations & Culture","permalink":"/lynx-onboarding/docs/module-1/team-expectations-culture"}},{"id":"module-1/first-30-days","title":"1.3 Your First 30 Days","description":"This is your roadmap for month one. Work through it week by week and bring it to every check-in. Completion of this checklist is required before your 30-day review with your Mentor.","source":"@site/docs/module-1/first-30-days.md","sourceDirName":"module-1","slug":"/module-1/first-30-days","permalink":"/lynx-onboarding/docs/module-1/first-30-days","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"first-30-days","title":"1.3 Your First 30 Days"},"sidebar":"docsSidebar","previous":{"title":"1.2 Team Structure & Who to Ask","permalink":"/lynx-onboarding/docs/module-1/team-structure"},"next":{"title":"1.4 Alberta Licensing in Plain English","permalink":"/lynx-onboarding/docs/module-1/alberta-licensing"}},{"id":"module-1/team-expectations-culture","title":"1.5 Team Expectations & Culture","description":"This isn't a list of rules to memorize. It's how we operate. The agents who thrive at Lynx aren't just good at real estate — they're good teammates. Read this once, then come back to it if something feels off.","source":"@site/docs/module-1/team-expectations-culture.md","sourceDirName":"module-1","slug":"/module-1/team-expectations-culture","permalink":"/lynx-onboarding/docs/module-1/team-expectations-culture","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"team-expectations-culture","title":"1.5 Team Expectations & Culture"},"sidebar":"docsSidebar","previous":{"title":"1.4 Alberta Licensing in Plain English","permalink":"/lynx-onboarding/docs/module-1/alberta-licensing"},"next":{"title":"2.1 Follow Up Boss","permalink":"/lynx-onboarding/docs/module-2/follow-up-boss"}},{"id":"module-1/team-structure","title":"1.2 Team Structure & Who to Ask","description":"You will have questions you don't know the answer to. That’s expected and normal. What matters is knowing who to ask — and asking before your client notices you don’t know.","source":"@site/docs/module-1/team-structure.md","sourceDirName":"module-1","slug":"/module-1/team-structure","permalink":"/lynx-onboarding/docs/module-1/team-structure","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"team-structure","title":"1.2 Team Structure & Who to Ask"},"sidebar":"docsSidebar","previous":{"title":"1.1 Our Team & What We Stand For","permalink":"/lynx-onboarding/docs/module-1/team-values"},"next":{"title":"1.3 Your First 30 Days","permalink":"/lynx-onboarding/docs/module-1/first-30-days"}},{"id":"module-1/team-values","title":"1.1 Our Team & What We Stand For","description":"Who we are","source":"@site/docs/module-1/team-values.md","sourceDirName":"module-1","slug":"/module-1/team-values","permalink":"/lynx-onboarding/docs/module-1/team-values","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"team-values","title":"1.1 Our Team & What We Stand For"},"sidebar":"docsSidebar","previous":{"title":"LYNX Real Estate Group Onboarding Guide","permalink":"/lynx-onboarding/docs/intro"},"next":{"title":"1.2 Team Structure & Who to Ask","permalink":"/lynx-onboarding/docs/module-1/team-structure"}},{"id":"module-2/digital-documents-esignatures","title":"2.5 Digital Documents & E-Signatures","description":"","source":"@site/docs/module-2/digital-documents-esignatures.md","sourceDirName":"module-2","slug":"/module-2/digital-documents-esignatures","permalink":"/lynx-onboarding/docs/module-2/digital-documents-esignatures","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"digital-documents-esignatures","title":"2.5 Digital Documents & E-Signatures"},"sidebar":"docsSidebar","previous":{"title":"2.4 Team Communication","permalink":"/lynx-onboarding/docs/module-2/team-communication"},"next":{"title":"3.1 The Inbound Lead Call","permalink":"/lynx-onboarding/docs/module-3/inbound-lead-call"}},{"id":"module-2/follow-up-boss","title":"2.1 Follow Up Boss","description":"Follow Up Boss is your command centre. Every lead, every conversation, every follow-up lives here. If it isn't in FUB, it didn't happen. Master this before anything else in Module 2.","source":"@site/docs/module-2/follow-up-boss.md","sourceDirName":"module-2","slug":"/module-2/follow-up-boss","permalink":"/lynx-onboarding/docs/module-2/follow-up-boss","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"follow-up-boss","title":"2.1 Follow Up Boss"},"sidebar":"docsSidebar","previous":{"title":"1.5 Team Expectations & Culture","permalink":"/lynx-onboarding/docs/module-1/team-expectations-culture"},"next":{"title":"2.2 MLS & ShowingTime","permalink":"/lynx-onboarding/docs/module-2/mls-showingtime"}},{"id":"module-2/marketing-tools","title":"2.3 Marketing Tools","description":"Your marketing is your brand. Every post, every graphic, every piece of content you put out represents you and Lynx. Done well, it builds trust before a client ever meets you. Done poorly, it costs you deals you'll never know you lost.","source":"@site/docs/module-2/marketing-tools.md","sourceDirName":"module-2","slug":"/module-2/marketing-tools","permalink":"/lynx-onboarding/docs/module-2/marketing-tools","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"marketing-tools","title":"2.3 Marketing Tools"},"sidebar":"docsSidebar","previous":{"title":"2.2 MLS & ShowingTime","permalink":"/lynx-onboarding/docs/module-2/mls-showingtime"},"next":{"title":"2.4 Team Communication","permalink":"/lynx-onboarding/docs/module-2/team-communication"}},{"id":"module-2/mls-showingtime","title":"2.2 MLS & ShowingTime","description":"MLS is where every active listing in Calgary lives. ShowingTime is how you book access to them. You'll use both of these every single day — knowing them well makes you look like a pro in front of clients from day one.","source":"@site/docs/module-2/mls-showingtime.md","sourceDirName":"module-2","slug":"/module-2/mls-showingtime","permalink":"/lynx-onboarding/docs/module-2/mls-showingtime","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"mls-showingtime","title":"2.2 MLS & ShowingTime"},"sidebar":"docsSidebar","previous":{"title":"2.1 Follow Up Boss","permalink":"/lynx-onboarding/docs/module-2/follow-up-boss"},"next":{"title":"2.3 Marketing Tools","permalink":"/lynx-onboarding/docs/module-2/marketing-tools"}},{"id":"module-2/team-communication","title":"2.4 Team Communication","description":"Slack is how the Lynx team operates day to day. Good communication here makes everything run smoother — for you, for your clients, and for the team. Learn how we use it in the first week and it becomes second nature fast.","source":"@site/docs/module-2/team-communication.md","sourceDirName":"module-2","slug":"/module-2/team-communication","permalink":"/lynx-onboarding/docs/module-2/team-communication","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"team-communication","title":"2.4 Team Communication"},"sidebar":"docsSidebar","previous":{"title":"2.3 Marketing Tools","permalink":"/lynx-onboarding/docs/module-2/marketing-tools"},"next":{"title":"2.5 Digital Documents & E-Signatures","permalink":"/lynx-onboarding/docs/module-2/digital-documents-esignatures"}},{"id":"module-3/buyer-consultation","title":"3.2 The Buyer Consultation","description":"","source":"@site/docs/module-3/buyer-consultation.md","sourceDirName":"module-3","slug":"/module-3/buyer-consultation","permalink":"/lynx-onboarding/docs/module-3/buyer-consultation","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"buyer-consultation","title":"3.2 The Buyer Consultation"},"sidebar":"docsSidebar","previous":{"title":"3.1 The Inbound Lead Call","permalink":"/lynx-onboarding/docs/module-3/inbound-lead-call"},"next":{"title":"3.3 Showings","permalink":"/lynx-onboarding/docs/module-3/showings"}},{"id":"module-3/inbound-lead-call","title":"3.1 The Inbound Lead Call","description":"","source":"@site/docs/module-3/inbound-lead-call.md","sourceDirName":"module-3","slug":"/module-3/inbound-lead-call","permalink":"/lynx-onboarding/docs/module-3/inbound-lead-call","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"inbound-lead-call","title":"3.1 The Inbound Lead Call"},"sidebar":"docsSidebar","previous":{"title":"2.5 Digital Documents & E-Signatures","permalink":"/lynx-onboarding/docs/module-2/digital-documents-esignatures"},"next":{"title":"3.2 The Buyer Consultation","permalink":"/lynx-onboarding/docs/module-3/buyer-consultation"}},{"id":"module-3/offer-to-close","title":"3.5 Offer to Close","description":"","source":"@site/docs/module-3/offer-to-close.md","sourceDirName":"module-3","slug":"/module-3/offer-to-close","permalink":"/lynx-onboarding/docs/module-3/offer-to-close","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"offer-to-close","title":"3.5 Offer to Close"},"sidebar":"docsSidebar","previous":{"title":"3.4 Writing & Presenting an Offer","permalink":"/lynx-onboarding/docs/module-3/writing-presenting-offer"},"next":{"title":"4.1 Pre-Listing Prep","permalink":"/lynx-onboarding/docs/module-4/pre-listing-prep"}},{"id":"module-3/showings","title":"3.3 Showings","description":"","source":"@site/docs/module-3/showings.md","sourceDirName":"module-3","slug":"/module-3/showings","permalink":"/lynx-onboarding/docs/module-3/showings","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"showings","title":"3.3 Showings"},"sidebar":"docsSidebar","previous":{"title":"3.2 The Buyer Consultation","permalink":"/lynx-onboarding/docs/module-3/buyer-consultation"},"next":{"title":"3.4 Writing & Presenting an Offer","permalink":"/lynx-onboarding/docs/module-3/writing-presenting-offer"}},{"id":"module-3/writing-presenting-offer","title":"3.4 Writing & Presenting an Offer","description":"","source":"@site/docs/module-3/writing-presenting-offer.md","sourceDirName":"module-3","slug":"/module-3/writing-presenting-offer","permalink":"/lynx-onboarding/docs/module-3/writing-presenting-offer","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"writing-presenting-offer","title":"3.4 Writing & Presenting an Offer"},"sidebar":"docsSidebar","previous":{"title":"3.3 Showings","permalink":"/lynx-onboarding/docs/module-3/showings"},"next":{"title":"3.5 Offer to Close","permalink":"/lynx-onboarding/docs/module-3/offer-to-close"}},{"id":"module-4/listing-appointment","title":"4.2 The Listing Appointment","description":"A listing appointment is a structured conversation, not a presentation. The agents who win listings consistently aren't the ones who talk the most — they're the ones who listen first, then lead with confidence.","source":"@site/docs/module-4/listing-appointment.md","sourceDirName":"module-4","slug":"/module-4/listing-appointment","permalink":"/lynx-onboarding/docs/module-4/listing-appointment","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"listing-appointment","title":"4.2 The Listing Appointment"},"sidebar":"docsSidebar","previous":{"title":"4.1 Pre-Listing Prep","permalink":"/lynx-onboarding/docs/module-4/pre-listing-prep"},"next":{"title":"4.3 Listing Launch","permalink":"/lynx-onboarding/docs/module-4/listing-launch"}},{"id":"module-4/listing-launch","title":"4.3 Listing Launch","description":"Going live on MLS is a moment you only get once with each listing. The first 72 hours drive more traffic — and more offers — than any other point in the listing lifecycle. Get the launch right.","source":"@site/docs/module-4/listing-launch.md","sourceDirName":"module-4","slug":"/module-4/listing-launch","permalink":"/lynx-onboarding/docs/module-4/listing-launch","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"listing-launch","title":"4.3 Listing Launch"},"sidebar":"docsSidebar","previous":{"title":"4.2 The Listing Appointment","permalink":"/lynx-onboarding/docs/module-4/listing-appointment"},"next":{"title":"4.4 Offers & Negotiation on the Listing Side","permalink":"/lynx-onboarding/docs/module-4/offers-negotiation-listing-side"}},{"id":"module-4/offers-negotiation-listing-side","title":"4.4 Offers & Negotiation on the Listing Side","description":"An offer on the table is the moment everything you've done as a listing agent gets tested. How you handle the next few hours determines whether your seller walks away feeling like they got the best possible outcome — or not.","source":"@site/docs/module-4/offers-negotiation-listing-side.md","sourceDirName":"module-4","slug":"/module-4/offers-negotiation-listing-side","permalink":"/lynx-onboarding/docs/module-4/offers-negotiation-listing-side","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"offers-negotiation-listing-side","title":"4.4 Offers & Negotiation on the Listing Side"},"sidebar":"docsSidebar","previous":{"title":"4.3 Listing Launch","permalink":"/lynx-onboarding/docs/module-4/listing-launch"},"next":{"title":"4.5 Seller Communication Cadence","permalink":"/lynx-onboarding/docs/module-4/seller-communication-cadence"}},{"id":"module-4/pre-listing-prep","title":"4.1 Pre-Listing Prep","description":"You win the listing before you walk in the door. The preparation you do in the 24 hours before a seller appointment is what separates an agent who gets hired from one who gets thanked and shown out.","source":"@site/docs/module-4/pre-listing-prep.md","sourceDirName":"module-4","slug":"/module-4/pre-listing-prep","permalink":"/lynx-onboarding/docs/module-4/pre-listing-prep","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"pre-listing-prep","title":"4.1 Pre-Listing Prep"},"sidebar":"docsSidebar","previous":{"title":"3.5 Offer to Close","permalink":"/lynx-onboarding/docs/module-3/offer-to-close"},"next":{"title":"4.2 The Listing Appointment","permalink":"/lynx-onboarding/docs/module-4/listing-appointment"}},{"id":"module-4/seller-communication-cadence","title":"4.5 Seller Communication Cadence","description":"","source":"@site/docs/module-4/seller-communication-cadence.md","sourceDirName":"module-4","slug":"/module-4/seller-communication-cadence","permalink":"/lynx-onboarding/docs/module-4/seller-communication-cadence","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"seller-communication-cadence","title":"4.5 Seller Communication Cadence"},"sidebar":"docsSidebar","previous":{"title":"4.4 Offers & Negotiation on the Listing Side","permalink":"/lynx-onboarding/docs/module-4/offers-negotiation-listing-side"},"next":{"title":"5.1 How Leads Work on Our Team","permalink":"/lynx-onboarding/docs/module-5/how-leads-work"}},{"id":"module-5/how-leads-work","title":"5.1 How Leads Work on Our Team","description":"Leads are the lifeblood of this business. Understanding how they're assigned, tracked, and protected isn't optional — it's foundational. Read this carefully.","source":"@site/docs/module-5/how-leads-work.md","sourceDirName":"module-5","slug":"/module-5/how-leads-work","permalink":"/lynx-onboarding/docs/module-5/how-leads-work","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"how-leads-work","title":"5.1 How Leads Work on Our Team"},"sidebar":"docsSidebar","previous":{"title":"4.5 Seller Communication Cadence","permalink":"/lynx-onboarding/docs/module-4/seller-communication-cadence"},"next":{"title":"5.2 Your Sphere of Influence","permalink":"/lynx-onboarding/docs/module-5/sphere-of-influence"}},{"id":"module-5/open-houses","title":"5.4 Open Houses","description":"An open house isn't just a favour to the seller. Done right, it's one of the highest-leverage lead generation activities you have. Two hours on a Sunday can change your pipeline for the month.","source":"@site/docs/module-5/open-houses.md","sourceDirName":"module-5","slug":"/module-5/open-houses","permalink":"/lynx-onboarding/docs/module-5/open-houses","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"open-houses","title":"5.4 Open Houses"},"sidebar":"docsSidebar","previous":{"title":"5.3 Scripts & Objection Handling","permalink":"/lynx-onboarding/docs/module-5/scripts-objection-handling"},"next":{"title":"5.5 Reviews, Referrals & Staying in Touch","permalink":"/lynx-onboarding/docs/module-5/reviews-referrals-staying-in-touch"}},{"id":"module-5/reviews-referrals-staying-in-touch","title":"5.5 Reviews, Referrals & Staying in Touch","description":"Closing the deal is the beginning of the relationship, not the end of it. The clients who feel taken care of after the transaction are the ones who send you business for the next ten years.","source":"@site/docs/module-5/reviews-referrals-staying-in-touch.md","sourceDirName":"module-5","slug":"/module-5/reviews-referrals-staying-in-touch","permalink":"/lynx-onboarding/docs/module-5/reviews-referrals-staying-in-touch","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"reviews-referrals-staying-in-touch","title":"5.5 Reviews, Referrals & Staying in Touch"},"sidebar":"docsSidebar","previous":{"title":"5.4 Open Houses","permalink":"/lynx-onboarding/docs/module-5/open-houses"}},{"id":"module-5/scripts-objection-handling","title":"5.3 Scripts & Objection Handling","description":"Every objection is a question in disguise. Your job isn't to overcome it — it's to understand what's behind it and respond with confidence. Keep responses short. Never argue. Always follow up with a question.","source":"@site/docs/module-5/scripts-objection-handling.md","sourceDirName":"module-5","slug":"/module-5/scripts-objection-handling","permalink":"/lynx-onboarding/docs/module-5/scripts-objection-handling","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"scripts-objection-handling","title":"5.3 Scripts & Objection Handling"},"sidebar":"docsSidebar","previous":{"title":"5.2 Your Sphere of Influence","permalink":"/lynx-onboarding/docs/module-5/sphere-of-influence"},"next":{"title":"5.4 Open Houses","permalink":"/lynx-onboarding/docs/module-5/open-houses"}},{"id":"module-5/sphere-of-influence","title":"5.2 Your Sphere of Influence","description":"No lead source will ever outperform the people who already know, like, and trust you. Your sphere isn't a backup plan — it's the foundation of a long-term real estate career.","source":"@site/docs/module-5/sphere-of-influence.md","sourceDirName":"module-5","slug":"/module-5/sphere-of-influence","permalink":"/lynx-onboarding/docs/module-5/sphere-of-influence","draft":false,"unlisted":false,"tags":[],"version":"current","frontMatter":{"id":"sphere-of-influence","title":"5.2 Your Sphere of Influence"},"sidebar":"docsSidebar","previous":{"title":"5.1 How Leads Work on Our Team","permalink":"/lynx-onboarding/docs/module-5/how-leads-work"},"next":{"title":"5.3 Scripts & Objection Handling","permalink":"/lynx-onboarding/docs/module-5/scripts-objection-handling"}}],"drafts":[],"sidebars":{"docsSidebar":[{"type":"doc","id":"intro"},{"type":"category","label":"Module 1 · Welcome to the Team","items":[{"type":"doc","id":"module-1/team-values"},{"type":"doc","id":"module-1/team-structure"},{"type":"doc","id":"module-1/first-30-days"},{"type":"doc","id":"module-1/alberta-licensing"},{"type":"doc","id":"module-1/team-expectations-culture"}],"collapsed":true,"collapsible":true},{"type":"category","label":"Module 2 · Your Tech Stack","items":[{"type":"doc","id":"module-2/follow-up-boss"},{"type":"doc","id":"module-2/mls-showingtime"},{"type":"doc","id":"module-2/marketing-tools"},{"type":"doc","id":"module-2/team-communication"},{"type":"doc","id":"module-2/digital-documents-esignatures"}],"collapsed":true,"collapsible":true},{"type":"category","label":"Module 3 · Working With Buyers","items":[{"type":"doc","id":"module-3/inbound-lead-call"},{"type":"doc","id":"module-3/buyer-consultation"},{"type":"doc","id":"module-3/showings"},{"type":"doc","id":"module-3/writing-presenting-o